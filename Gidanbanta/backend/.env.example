# Application
APP_NAME=MatchHang
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/matchhang
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CHAT_DB=1
REDIS_SESSION_DB=2

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Payment Providers
OPAY_API_KEY=your-opay-key
OPAY_MERCHANT_ID=your-merchant-id
PALMPAY_API_KEY=your-palmpay-key
MONIEPOINT_API_KEY=your-moniepoint-key

# Streaming
HLS_SECRET_KEY=your-hls-secret
STREAM_TOKEN_EXPIRE_HOURS=3

# Football API (API-Football)
FOOTBALL_API_KEY=your-api-football-key
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# Moderation
MODERATION_API_KEY=your-moderation-api-key
AUTO_MODERATE=True

# Celery
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4

# App Settings
CHAT_UNLOCK_PRICE=100
FREE_MESSAGES_PER_MATCH=3
MIN_AGE=18
KYC_REQUIRED_FOR_PURCHASE=True
